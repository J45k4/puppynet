<Form action="/auth/login" method="post" spacing=8 fill=true maxWidth=360>
  <Text value="Login" />
  <TextInput name="username" value={state.login_username} placeholder="Username" fill=true />
  <TextInput name="password" value={state.login_password} placeholder="Password" type="password" fill=true />
  <If test={state.login_error != ""}>
    <Text value={state.login_error} color="#b30000" />
  </If>
  <Button text="Login" />
</Form>
